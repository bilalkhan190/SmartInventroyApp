{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SmartInventoryDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "SmartInventory.Api",
    "Audience": "SmartInventory.Client",
    "Key": "replace-with-a-random-secret-at-least-32-bytes-long",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "SeedAdmin": {
    "Username": "admin",
    "Password": "choose-a-local-development-password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
